# Frontend → copy to frontend/.env
VITE_API_BASE_URL=http://localhost:8000
VITE_DEV_PORT=5173
VITE_MAX_FILE_SIZE_MB=10
VITE_MIN_JD_LENGTH=50
VITE_MAX_JD_LENGTH=5000

# Backend → copy to backend/.env
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_FOLDER=user_uploads
UPLOAD_CHUNK_SIZE_MB=1
DEFAULT_EXPERIENCE_SCORE=75
UVICORN_RELOAD=true
UVICORN_RELOAD_EXCLUDES=app/parser.py
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
JOBBERT_MODEL=jjzha/jobbert_skill_extraction
SPACY_MODEL=en_core_web_sm

# Optional
# HF_TOKEN=
